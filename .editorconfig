# EditorConfig - https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,ts,jsx,tsx,json,yml,yaml,html,css,xml,vue,svelte}]
indent_size = 2

[Makefile]
indent_style = tab

[*.mk]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_size = 2